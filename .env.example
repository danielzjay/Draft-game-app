# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PAYMENT_BACKEND_BASE_URL: Your OWN backend that proxies Relworx calls.
# Never put a Relworx URL with a bundled secret key here — this must point to a server you
# control. relworx.php now lives at https://awishworldgroup.xyz/Manager/relworx.php
# Must end in a trailing slash, and represent the directory containing relworx.php:
PAYMENT_BACKEND_BASE_URL=https://awishworldgroup.xyz/Manager/
