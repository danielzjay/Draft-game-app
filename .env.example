# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PAYMENT_BACKEND_BASE_URL: Your OWN backend that proxies Relworx calls.
# Never put a Relworx URL with a bundled secret key here — this must point to a server you
# control (e.g. your deployed Firebase Cloud Function). See /server/relworxProxy.js.
# Must end in a trailing slash, and include the function name if using Cloud Functions:
PAYMENT_BACKEND_BASE_URL=https://us-central1-draughts-combat1.cloudfunctions.net/relworxProxy/
