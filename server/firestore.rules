rules_version = '2';

// Paste this into Firebase Console -> Firestore Database -> Rules -> Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{docId} {
      // Anyone (signed in or not) can READ the leaderboard.
      allow read: if true;

      // A real player can only write THEIR OWN entry (doc ID == their uid).
      allow create, update: if request.auth != null
        && request.auth.uid == docId
        && request.resource.data.mmr is int
        && request.resource.data.mmr >= 0
        && request.resource.data.mmr <= 5000 // sanity ceiling — adjust to your real max MMR
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.isBot == false;

      // Bot persona entries (doc IDs like "bot_grandmasterx") — any signed-in player can update
      // a bot's score after playing it, but only by a small bounded amount per write, since bots
      // have no real Firebase Auth account of their own to restrict writes to. This is a
      // reasonable bound for a cosmetic/flavor leaderboard entry, not real security — a
      // determined client could still spam small legal writes. Don't treat bot rankings as
      // trustworthy competitive data.
      allow create: if request.auth != null
        && docId.matches('bot_.*')
        && request.resource.data.isBot == true
        && request.resource.data.mmr is int
        && request.resource.data.mmr >= 0
        && request.resource.data.mmr <= 5000;

      allow update: if request.auth != null
        && docId.matches('bot_.*')
        && request.resource.data.isBot == true
        && request.resource.data.mmr is int
        && request.resource.data.mmr >= 0
        && request.resource.data.mmr <= 5000
        && (request.resource.data.mmr - resource.data.mmr) >= -20
        && (request.resource.data.mmr - resource.data.mmr) <= 20;

      allow delete: if false;
    }

    // Matchmaking queue: your own entry only. Anyone can READ the queue (needed to find an
    // opponent), but only you can create/update/delete your own doc.
    match /matchmaking_queue/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Live 1v1 matches. Both participants can read; only a participant can write, and only to
    // their own match. This does NOT validate that a pushed board is a legal draughts position —
    // that would need a Cloud Function. A modified client could push an illegal board; this only
    // guarantees a stranger outside the match can't touch it.
    match /online_matches/{matchId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.player1Uid || request.auth.uid == resource.data.player2Uid);
      allow create: if request.auth != null
        && (request.auth.uid == request.resource.data.player1Uid || request.auth.uid == request.resource.data.player2Uid);
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.player1Uid || request.auth.uid == resource.data.player2Uid);
      allow delete: if false;
    }

    // Tournaments: anyone can read (browsing open competitions); only the organizer can create/
    // edit their own tournament doc; registration additions are handled by the register() flow
    // (still gated to being signed in — Firestore rules can't easily diff "only added yourself
    // to the array" without a Cloud Function, so this is a reasonable client-side bound, not
    // airtight against a modified client editing someone else's registration list).
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.organizerUid;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /tournament_fixtures/{fixtureId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
