rules_version = '2';

// Paste this into Firebase Console -> Firestore Database -> Rules -> Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{uid} {
      // Anyone (signed in or not) can READ the leaderboard.
      allow read: if true;

      // Only the signed-in owner of a doc can write THEIR OWN entry (doc ID == their uid).
      // Nobody can write to another player's entry.
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.mmr is int
        && request.resource.data.mmr >= 0
        && request.resource.data.mmr <= 5000 // sanity ceiling — adjust to your real max MMR
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40;

      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
